{
  "name": "waibspace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently --kill-others --names \"backend,frontend\" --prefix-colors \"blue,green\" \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:frontend": "bun --filter @waibspace/frontend dev",
    "dev:backend": "bun --filter @waibspace/backend dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
