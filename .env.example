# Server
PORT=3001

# AI Model Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here       # Required
OPENAI_API_KEY=your_openai_api_key_here             # Optional

# Gmail Connector (optional — omit to skip Gmail features)
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Google Calendar Connector (optional — omit to skip Calendar features)
GCAL_CLIENT_ID=your_gcal_client_id_here
GCAL_CLIENT_SECRET=your_gcal_client_secret_here
GCAL_REFRESH_TOKEN=your_gcal_refresh_token_here
GCAL_REDIRECT_URI=http://localhost:3001/oauth/callback
